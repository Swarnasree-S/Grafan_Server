
7days interval display query:
----------------------------------

SELECT
  'daily' AS type,
  MAX(CASE WHEN DATE(weatherdate) = CURDATE() THEN weathercode END) AS Day1,
  MAX(CASE WHEN DATE(weatherdate) = CURDATE() + INTERVAL 1 DAY THEN weathercode END) AS Day2,
  MAX(CASE WHEN DATE(weatherdate) = CURDATE() + INTERVAL 2 DAY THEN weathercode END) AS Day3,
  MAX(CASE WHEN DATE(weatherdate) = CURDATE() + INTERVAL 3 DAY THEN weathercode END) AS Day4,
  MAX(CASE WHEN DATE(weatherdate) = CURDATE() + INTERVAL 4 DAY THEN weathercode END) AS Day5,
  MAX(CASE WHEN DATE(weatherdate) = CURDATE() + INTERVAL 5 DAY THEN weathercode END) AS Day6,
  MAX(CASE WHEN DATE(weatherdate) = CURDATE() + INTERVAL 6 DAY THEN weathercode END) AS Day7
FROM weatherdaily
WHERE plantid = 23
  AND wmsstatus = 'daily'
  AND weatherdate BETWEEN CURDATE() 
                      AND CURDATE() + INTERVAL 6 DAY;


query to update current status:
----------------------
SELECT weathercode
FROM weatherdaily
WHERE plantid = 66
AND wmsstatus = 'current'
ORDER BY createddate DESC
LIMIT 1;



