          "rawQuery": true,
          "rawSql": "SELECT\r\n  FROM_UNIXTIME(`timestamp`) AS Time,\r\n  datalogger_id AS MAC,\r\n  device_id AS device_id,\r\n  plant_name AS Plant,\r\n  alert AS `Alert Message`,\r\n  event_code AS `Event Code`,\r\n  status_code AS `Status Code`,\r\n  mobile AS Recipient,\r\n  alert_type AS `Type`\r\nFROM alert_logs\r\nWHERE $__unixEpochFilter(`timestamp`)\r\n  AND plant_name IN ($plant_name)\r\n  AND alert IN ($alert)\r\n  AND alert_type IN ($alert_type)\r\n  AND device_id IN ($device_id)\r\nORDER BY Time DESC;\r\n",
